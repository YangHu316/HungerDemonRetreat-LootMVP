; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="HungerDemonRetreat_LootMVP"
run/main_scene="res://scenes/menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoloads/event_bus.gd"
GameSession="*res://scripts/autoloads/game_session.gd"
PlayerInventory="*res://scripts/autoloads/player_inventory.gd"
Stamina="*res://scripts/autoloads/stamina.gd"
Logger="*res://scripts/utils/logger.gd"
Stash="*res://scripts/autoloads/stash.gd"
OrderPool="*res://scripts/autoloads/order_pool.gd"
MultiplayerManager="*res://scripts/autoloads/multiplayer_manager.gd"
LocalInspectLog="*res://scripts/autoloads/local_inspect_log.gd"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[gui]

theme/custom="res://default_theme.tres"

